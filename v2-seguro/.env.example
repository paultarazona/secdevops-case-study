# Copy this file to .env and fill in real values. Never commit a real .env.

# HTTP
PORT=43172
NODE_ENV=development

# CORS - explicit allowed origin, never '*'
CORS_ORIGIN=http://localhost:5173

# JWT
# Generate a strong random secret for real use, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_PATH=./data/v2-seguro.db

# Rate limiting (login/register brute-force protection)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# Uploads
UPLOAD_MAX_BYTES=5242880
